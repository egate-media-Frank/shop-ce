# Satellite working tree for shop-demodata-ce. Cloned at top level (not in
# vendor/) so PhpStorm's Composer integration doesn't auto-exclude it; the
# entrypoint then symlinks vendor/o3-shop/shop-demodata-ce -> here so
# composer/code paths keep working unchanged.
/shop-demodata-ce
/source/out/pictures/generated/*
/source/out/pictures/master/category/*

/source/out/pictures/master/manufacturer/*
/source/out/pictures/master/product/*
/source/out/pictures/master/wrapping/img_ecard_03_wp.jpg
/source/out/pictures/promo/*
/source/out/wave
/source/out/o3-theme
/var/configuration/shops/1.yaml
/var/generated/generated_services.yaml
docker/database/data
docker/mailpit/data
coverage

