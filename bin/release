// Silence E_DEPRECATED noise from the vendored Symfony Console 3.4 +
// react/promise on PHP 8.4+. The constraints are pinned by the shop's
// composer.json; bumping them is out of scope for this CLI. Other
// error levels stay visible.
error_reporting(error_reporting() & ~E_DEPRECATED & ~E_USER_DEPRECATED);

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',          // shop-ce as project root
    __DIR__ . '/../../../autoload.php',           // shop-ce inside vendor/
];
$autoloadFound = false;
foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        require_once $candidate;
        $autoloadFound = true;
        break;
    }
}
if (!$autoloadFound) {
    fwrite(STDERR, "bin/release: composer autoload.php not found.\n");
    exit(1);
}

use OxidEsales\EshopCommunity\Internal\ReleaseTooling\Command\ReleaseCommand;
use Symfony\Component\Console\Application;

$command = new ReleaseCommand();
$application = new Application('o3-shop release CLI', 'dev');
$application->add($command);
$application->setDefaultCommand($command->getName(), true);
exit($application->run());
